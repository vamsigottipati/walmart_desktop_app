{
  "name": "walmart-company-enrichment",
  "version": "1.0.0",
  "description": "A classy, glass-morphism company data enrichment desktop app for Walmart teams.",
  "main": "main.js",
  "scripts": {
    "build-css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "watch-css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "dev": "npm run build-css && electron .",
    "build": "npm run build-css && electron-builder",
    "postinstall": "npm run build-css"
  },
  "keywords": [
    "electron",
    "walmart",
    "enrichment",
    "tailwindcss"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^3.4.0"
  },
  "build": {
    "appId": "com.example.walmart-enrichment",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "dist/**/*",
      "tailwind.config.js"
    ]
  }
}
